# ============================================
# ConsultPro B2B Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# NODE ENVIRONMENT
# ============================================
# Environment mode: development, production, or test
NODE_ENV=development

# Server port (default: 3000)
PORT=3000

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example: postgresql://postgres:password@localhost:5432/consultpro
DATABASE_URL="postgresql://postgres:password@localhost:5432/consultpro"

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# JWT secret for signing authentication tokens
# REQUIRED: Must be at least 32 characters for security
# Generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-min-32-characters-required-change-this-in-production"

# NextAuth configuration (if using NextAuth)
NEXTAUTH_SECRET="your-nextauth-secret-min-32-characters-required-change-this"
NEXTAUTH_URL="http://localhost:3000"

# CSRF Protection secret (optional, auto-generated if not provided)
# REQUIRED in production: Must be at least 32 characters
# Generate with: openssl rand -base64 32
CSRF_SECRET="your-csrf-secret-min-32-characters-required-change-this"

# Disable CSRF protection (for development/testing only, default: false)
# WARNING: Never disable in production!
DISABLE_CSRF=false

# ============================================
# CLOUDINARY CONFIGURATION
# ============================================
# Cloudinary credentials for file uploads and media management
# Get your credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ============================================
# ZOOM INTEGRATION
# ============================================
# Zoom API credentials for video conferencing
# Get your credentials from: https://marketplace.zoom.us/
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# ============================================
# REDIS CONFIGURATION (Optional)
# ============================================
# Redis URL for rate limiting and caching
# If not provided, falls back to in-memory storage (not recommended for production)
# Format: redis://default:password@host:port or rediss:// for TLS
# For Upstash Redis: https://console.upstash.com/
REDIS_URL=
REDIS_TOKEN=

# ============================================
# RATE LIMITING CONFIGURATION (Optional)
# ============================================
# Override default rate limits (requests per time window)
# Default limits are defined in src/lib/ratelimit/config.ts

# Default rate limit for all endpoints (default: 100 requests per 15 minutes)
RATE_LIMIT_DEFAULT=100

# Rate limit for authentication endpoints (default: 5 requests per 15 minutes)
RATE_LIMIT_AUTH=5

# Rate limit for file upload endpoints (default: 20 requests per 1 minute)
RATE_LIMIT_UPLOAD=20

# ============================================
# ERROR MONITORING - SENTRY (Optional)
# ============================================
# Sentry configuration for error tracking and monitoring
# Get your DSN from: https://sentry.io/
# If not provided, errors will only be logged locally
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ============================================
# LOGGING CONFIGURATION
# ============================================
# Minimum log level: debug, info, warn, error
# Recommended: info for production, debug for development
LOG_LEVEL=info

# ============================================
# RECAPTCHA CONFIGURATION (Optional)
# ============================================
# Google reCAPTCHA for bot protection
# Get your keys from: https://www.google.com/recaptcha
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ============================================
# SECURITY NOTES
# ============================================
# 1. JWT_SECRET must be at least 32 characters in production
# 2. CSRF_SECRET must be at least 32 characters in production
# 3. Never use default/example secrets in production
# 4. Use strong, randomly generated secrets
# 5. Rotate secrets regularly (every 90 days recommended)
# 6. Keep .env file secure and never commit to version control
# 7. Use environment-specific .env files (.env.production, .env.staging)
# 8. Redis is highly recommended for production rate limiting
# 9. Sentry is highly recommended for production error monitoring
# 10. Set NODE_ENV=production in production environments

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to production, ensure:
# [ ] All REQUIRED variables are set with production values
# [ ] JWT_SECRET is at least 32 characters and randomly generated
# [ ] CSRF_SECRET is at least 32 characters and randomly generated
# [ ] DATABASE_URL points to production database
# [ ] REDIS_URL is configured for production Redis instance
# [ ] SENTRY_DSN is configured for error monitoring
# [ ] NODE_ENV is set to "production"
# [ ] LOG_LEVEL is set to "info" or "warn"
# [ ] DISABLE_CSRF is set to false or removed
# [ ] All secrets are different from development/staging
# [ ] Cloudinary and Zoom credentials are for production accounts
# [ ] NEXTAUTH_URL points to production domain
