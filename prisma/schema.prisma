generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String?
  firstName     String?
  phone         String?
  company       String?
  sector        String?
  address       String?
  needs         String?
  role          Role           @default(CLIENT)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  missionFiles  MissionFile[]
  notifications Notification[]
  orders        Order[]
  reservations  Reservation[]
  invoices      Invoice[]
  reviews       Review[]
}

model Consultant {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String
  firstName    String?
  phone        String?
  specialty    String?
  hourlyRate   Decimal?      @db.Decimal(10, 2)
  bio          String?
  imageUrl     String?
  isActive     Boolean       @default(true)
  cvUrl        String?
  certifications String[]
  createdAt    DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  missions      Mission[]
  orders        Order[]
  reservations  Reservation[]
  services      Service[]
  notifications Notification[]
  reviews       Review[]
  avgRating     Float         @default(0)
  reviewCount   Int           @default(0)
}

model Service {
  id          String        @id @default(cuid())
  name        String
  description String
  category    String?
  logo        String?
  icon        String?
  image       String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tiers       ServiceTier[]
  consultants Consultant[]
  reviews     Review[]
  avgRating   Float         @default(0)
  reviewCount Int           @default(0)
}

model ServiceTier {
  id                  String        @id @default(cuid())
  serviceId           String
  tierType            TierType
  price               Decimal       @db.Decimal(10, 2)
  maxMessages         Int?
  maxCallDuration     Int?
  canSelectConsultant Boolean       @default(false)
  description         String?
  sessionsConfig      Json?
  createdAt           DateTime      @default(now())
  orders              Order[]
  reservations        Reservation[]
  service             Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model Order {
  id              String      @id @default(cuid())
  clientId        String
  consultantId    String?
  serviceTierId   String
  status          OrderStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(CARD)
  messagesUsed    Int         @default(0)
  callMinutesUsed Int         @default(0)
  createdAt       DateTime    @default(now())
  closedAt        DateTime?
  calls           Call[]
  messages        Message[]
  missions        Mission[]
  reservations    Reservation[]
  client          User        @relation(fields: [clientId], references: [id])
  consultant      Consultant? @relation(fields: [consultantId], references: [id])
  serviceTier     ServiceTier @relation(fields: [serviceTierId], references: [id])

  invoices        Invoice[]
  reviews         Review[]

  @@index([clientId])
  @@index([consultantId])
  @@index([status])
}

model Message {
  id         String     @id @default(cuid())
  orderId    String
  senderId   String
  senderType SenderType
  content    String
  createdAt  DateTime   @default(now())
  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)


  @@index([orderId])
}

model Call {
  id           String    @id @default(cuid())
  orderId      String
  duration     Int
  startedAt    DateTime
  endedAt      DateTime?
  recordingUrl String?
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Mission {
  id           String        @id @default(cuid())
  orderId      String
  consultantId String
  title        String
  description  String?
  status       MissionStatus @default(PENDING)
  startedAt    DateTime?
  closedAt     DateTime?
  createdAt    DateTime      @default(now())
  milestones   Milestone[]
  consultant   Consultant    @relation(fields: [consultantId], references: [id])
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  files        MissionFile[]

  @@index([orderId])
  @@index([consultantId])
}

model Milestone {
  id          String          @id @default(cuid())
  missionId   String
  title       String
  description String?
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  mission     Mission         @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
}

model MissionFile {
  id           String   @id @default(cuid())
  missionId    String
  uploadedById String
  fileName     String
  fileUrl      String
  fileType     String
  createdAt    DateTime @default(now())
  mission      Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@index([missionId])
}

model Reservation {
  id            String            @id @default(cuid())
  clientId      String
  consultantId  String
  serviceTierId String
  startTime     DateTime
  endTime       DateTime
  status        ReservationStatus @default(PENDING)
  meetingType   MeetingType       @default(ZOOM)
  sessionIndex  Int               @default(0)
  sessionLabel  String?
  zoomJoinUrl   String?
  zoomPassword  String?
  createdAt     DateTime          @default(now())
  orderId       String?
  order         Order?            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  client        User              @relation(fields: [clientId], references: [id])
  consultant    Consultant        @relation(fields: [consultantId], references: [id])
  serviceTier   ServiceTier       @relation(fields: [serviceTierId], references: [id])

  @@index([clientId])
  @@index([consultantId])
  @@index([orderId])
}

model Notification {
  id           String           @id @default(cuid())
  userId       String?
  consultantId String?
  type         NotificationType
  title        String
  message      String
  isRead       Boolean          @default(false)
  createdAt    DateTime         @default(now())
  user         User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultant   Consultant?      @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consultantId])
  @@index([isRead])
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  content   String
  excerpt   String?
  icon      String?
  image     String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id              String      @id @default(cuid())
  type            ReviewType
  rating          Int         // 1 to 5
  comment         String?     @db.Text
  
  // Relations
  clientId        String
  client          User        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Target: Consultant (Optional)
  consultantId    String?
  consultant      Consultant? @relation(fields: [consultantId], references: [id], onDelete: SetNull)
  
  // Target: Service/Order (Optional)
  orderId         String?
  order           Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  
  serviceId       String?
  service         Service?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  // Status for moderation
  isPublished     Boolean     @default(true)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([orderId, type])
  @@index([clientId])
  @@index([consultantId])
  @@index([serviceId])
}


enum Role {
  CLIENT
  CONSULTANT
  ADMIN
}

enum TierType {
  BASIC
  STANDARD
  PREMIUM
  ULTIMATE
}

enum OrderStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MissionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum SenderType {
  CLIENT
  CONSULTANT
}

enum UploaderType {
  CLIENT
  CONSULTANT
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MeetingType {
  ZOOM
  SUR_PLACE
}

enum NotificationType {
  ORDER
  MESSAGE
  CALL
  MISSION
  SYSTEM
  RESERVATION
  REVIEW
}

enum PaymentMethod {
  CARD
  VIREMENT
  SUR_PLACE
}

enum ReviewType {
  CONSULTANT
  SERVICE
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  clientId        String
  orderId         String?
  amount          Decimal       @db.Decimal(10, 2)
  status          InvoiceStatus @default(PENDING)
  issueDate       DateTime      @default(now())
  dueDate         DateTime
  paidAt          DateTime?
  pdfUrl          String?
  
  client          User          @relation(fields: [clientId], references: [id])
  order           Order?        @relation(fields: [orderId], references: [id])
  payments        Payment[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([clientId])
  @@index([orderId])
  @@index([status])
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod 
  status        String        
  transactionId String?       @unique
  
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  
  createdAt     DateTime      @default(now())

  @@index([invoiceId])
}

enum InvoiceStatus {
  PAID
  UNPAID
  PENDING
  CANCELLED
}
