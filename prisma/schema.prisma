generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  CONSULTANT
  ADMIN
}

enum TierType {
  BASIC
  STANDARD
  PREMIUM
}

enum OrderStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MissionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum SenderType {
  CLIENT
  CONSULTANT
}

enum UploaderType {
  CLIENT
  CONSULTANT
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  ORDER
  MESSAGE
  CALL
  MISSION
  SYSTEM
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String?
  phone         String?
  role          Role           @default(CLIENT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orders        Order[]
  messages      Message[]
  notifications Notification[]
  reservations  Reservation[]
  missionFiles  MissionFile[]
}

model Consultant {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String
  specialty    String?
  hourlyRate   Decimal?      @db.Decimal(10, 2)
  bio          String?
  imageUrl     String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  orders       Order[]
  missions     Mission[]
  reservations Reservation[]
}

model Service {
  id          String        @id @default(cuid())
  name        String
  description String
  category    String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tiers       ServiceTier[]
}

model ServiceTier {
  id                   String        @id @default(cuid())
  serviceId            String
  tierType             TierType
  price                Decimal       @db.Decimal(10, 2)
  maxMessages          Int?
  maxCallDuration      Int?
  canSelectConsultant  Boolean       @default(false)
  description          String?
  createdAt            DateTime      @default(now())
  service              Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  orders               Order[]
  reservations         Reservation[]

  @@index([serviceId])
}

model Order {
  id              String      @id @default(cuid())
  clientId        String
  consultantId    String?
  serviceTierId   String
  status          OrderStatus @default(PENDING)
  messagesUsed    Int         @default(0)
  callMinutesUsed Int         @default(0)
  createdAt       DateTime    @default(now())
  closedAt        DateTime?
  client          User        @relation(fields: [clientId], references: [id])
  consultant      Consultant? @relation(fields: [consultantId], references: [id])
  serviceTier     ServiceTier @relation(fields: [serviceTierId], references: [id])
  messages        Message[]
  calls           Call[]
  missions        Mission[]

  @@index([clientId])
  @@index([consultantId])
  @@index([status])
}

model Message {
  id         String     @id @default(cuid())
  orderId    String
  senderId   String
  senderType SenderType
  content    String
  createdAt  DateTime   @default(now())
  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender     User       @relation(fields: [senderId], references: [id])

  @@index([orderId])
}

model Call {
  id           String    @id @default(cuid())
  orderId      String
  duration     Int
  startedAt    DateTime
  endedAt      DateTime?
  recordingUrl String?
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Mission {
  id           String         @id @default(cuid())
  orderId      String
  consultantId String
  title        String
  description  String?
  status       MissionStatus  @default(PENDING)
  startedAt    DateTime?
  closedAt     DateTime?
  createdAt    DateTime       @default(now())
  order        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  consultant   Consultant     @relation(fields: [consultantId], references: [id])
  milestones   Milestone[]
  files        MissionFile[]

  @@index([orderId])
  @@index([consultantId])
}

model Milestone {
  id          String          @id @default(cuid())
  missionId   String
  title       String
  description String?
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  mission     Mission         @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
}

model MissionFile {
  id           String       @id @default(cuid())
  missionId    String
  uploadedById String
  fileName     String
  fileUrl      String
  fileType     String
  createdAt    DateTime     @default(now())
  mission      Mission      @relation(fields: [missionId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])

  @@index([missionId])
}

model Reservation {
  id             String            @id @default(cuid())
  clientId       String
  consultantId   String
  serviceTierId  String
  startTime      DateTime
  endTime        DateTime
  status         ReservationStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  client         User              @relation(fields: [clientId], references: [id])
  consultant     Consultant        @relation(fields: [consultantId], references: [id])
  serviceTier    ServiceTier       @relation(fields: [serviceTierId], references: [id])

  @@index([clientId])
  @@index([consultantId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  content   String
  excerpt   String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
